[flake8]
exclude =
    venv,
    .git,
    __pycache__,
    migrations,
    node_modules
max-line-length = 120
ignore =
    E128,
    E221,
    E241,
    E302,
    E305,
    E402,
    E501,
    E712,
    E722,
    F401,
    F403,
    F405,
    F811,
    F822,
    F824,
    F841,
    W291,
    W292,
    W293
